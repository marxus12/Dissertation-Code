# Mainb.py
from configb import POWER_CURVE_FILE, TURBINE_FILES, NEIGHBOR_MAP
from turbine_analyticsb import uib, data_iob, processingb

def run_application():
    try:
        # 1. Selection
        target_file = uib.select_turbine_dataset()
        
        # 2. Identify Metadata (T01 -> Deeping T1)
        t_id = target_file.split(' ')[1].replace('T','').lstrip('0')
        learned_sheet = f"Deeping T{t_id}"
        
        # 3. Load Data
        all_data = {f: data_iob.load_turbine_data(f) for f in TURBINE_FILES}
        target_df = all_data[target_file]
        neighbors = NEIGHBOR_MAP.get(target_file)
        
        # Load Power Curves
        pc_default = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, "Default PC")
        pc_learned = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, learned_sheet)

        # 4. Run the 6 Methods
        # We store the ENTIRE result (the 4-item tuple) into the dictionary
        print("\nCalculating all 6 methods... please wait.")
        results_map = {}
        
        results_map["1_Default_PC"] = processingb.method_1(target_df, pc_default, all_data, neighbors)
        results_map["2_Learned_PC"] = processingb.method_2(target_df, pc_learned, all_data, neighbors)
        results_map["3_Primary_WS_Ref"] = processingb.method_3(target_df, pc_learned, all_data, neighbors)
        results_map["4_Farm_WS_Ref"] = processingb.method_4(target_df, pc_learned, all_data, neighbors)
        results_map["5_Primary_kW_Ref"] = processingb.method_5(target_df, all_data, neighbors, pc_learned)
        results_map["6_Farm_kW_Ref"] = processingb.method_6(target_df, all_data, pc_learned)

        # 5. Export
        # We no longer need to pass 'ts_col' separately because it's inside the results_map tuples
        final_path = data_iob.export_all_methods(results_map, target_file)
        
        # 6. Final UI
        uib.display_final_status(final_path)

    except Exception as e:
        print(f"\nCRITICAL ERROR: {e}")
        # Uncomment the next line if you need to see exactly where it's failing
        # import traceback; traceback.print_exc()

if __name__ == "__main__":
    run_application()
