# data_iob.py
import pandas as pd
from configb import INTERVAL_HRS

def load_turbine_data(file_path):
    return pd.read_excel(file_path, usecols="A,B,C", header=0)

def load_power_curve_sheet(power_curve_file, sheet_name):
    excel_obj = pd.ExcelFile(power_curve_file)
    df_curve = pd.read_excel(excel_obj, sheet_name=sheet_name, header=0)
    df_curve.columns = ['WS_Ref', 'Power_Ref']
    return df_curve

def export_all_methods(results_dict, original_filename):
    output_name = f"Full_Analysis_{original_filename}"
    
    with pd.ExcelWriter(output_name, engine='xlsxwriter') as writer:
        print(f"\n--- Row Removal Report for {original_filename} ---")
        
        for m_name, (df, ts_col, is_on, is_stop) in results_dict.items():
            # Drop rows where all fallbacks failed (Power_Ref is NaN)
            initial_count = len(df)
            clean_df = df.dropna(subset=['Power_Ref']).copy()
            removed_count = initial_count - len(clean_df)
            
            print(f"Method {m_name:.<25}: {removed_count} rows removed.")

            # Identify the Actual Power column name (the 3rd column in the original file)
            actual_pwr_col = clean_df.columns[2]
            
            # Re-calculate subsets from cleaned data
            is_on_clean = clean_df[actual_pwr_col] > 0
            is_stop_clean = (~is_on_clean).fillna(True)
            
            clean_df[ts_col] = pd.to_datetime(clean_df[ts_col]).dt.strftime('%d-%m-%Y %H:%M')
            
            # --- CHANGE: Include actual_pwr_col in the exported columns ---
            cols = [ts_col, actual_pwr_col, 'Power_Ref']
            
            full_df = clean_df[cols]
            on_df = clean_df.loc[is_on_clean, cols].copy()
            on_df['Produced_Energy_kWh'] = on_df['Power_Ref'] * INTERVAL_HRS
            
            off_df = clean_df.loc[is_stop_clean, cols].copy()
            off_df['Lost_Energy_kWh'] = off_df['Power_Ref'] * INTERVAL_HRS

            # Write side-by-side
            full_df.to_excel(writer, sheet_name=m_name, index=False, startcol=0)
            on_df.to_excel(writer, sheet_name=m_name, index=False, startcol=4) # Adjusted startcol for spacing
            off_df.to_excel(writer, sheet_name=m_name, index=False, startcol=9) # Adjusted startcol for spacing

            # Formatting
            ws = writer.sheets[m_name]
            wb = writer.book
            h_fmt = wb.add_format({'bold': True, 'bg_color': '#D7E4BC', 'border': 1, 'align': 'center'})
            num_fmt = wb.add_format({'num_format': '#,##0.00'})

            ws.write(0, 0, "FULL DATASET", h_fmt)
            ws.write(0, 4, "TURBINE ON (Ref)", h_fmt)
            ws.write(0, 9, "TURBINE OFF (Loss)", h_fmt)
            
            # Adjusted column widths to accommodate the extra column
            ws.set_column('A:C', 18, num_fmt)
            ws.set_column('E:G', 18, num_fmt)
            ws.set_column('J:L', 18, num_fmt)
            
    print("-" * 45)
    return output_name

# processingb.py
import pandas as pd
import numpy as np

# --- INTERNAL HELPERS ---

def _get_active_only_values(dataframe, col_idx):
    """Filters for ON turbines only (used for Power-based methods)."""
    power_vals = dataframe.iloc[:, 2] # Column D
    target_vals = dataframe.iloc[:, col_idx]
    return target_vals.where(power_vals > 0, np.nan)

def _get_raw_ws_averages(all_data, turbine_list):
    """
    Averages Wind Speed (Col B) ONLY for turbines that are currently ON (Col C > 0).
    If a turbine is OFF or Power is NaN, its Wind Speed is excluded from the mean.
    """
    if not turbine_list:
        return pd.Series(np.nan)
        
    ws_data_points = []
    
    for t in turbine_list:
        if t in all_data:
            df = all_data[t]
            ws = df.iloc[:, 1]      # Column B (Wind Speed)
            pwr = df.iloc[:, 2]     # Column C (Actual Power)
            
            # Logic: Keep WS only where Power > 0, otherwise set to NaN
            # This ensures they are excluded from the .mean() calculation
            filtered_ws = ws.where(pwr > 0, np.nan)
            
            # Further safety: handle zero wind speeds that might be errors
            filtered_ws = filtered_ws.replace(0, np.nan)
            
            ws_data_points.append(filtered_ws)
            
    if not ws_data_points:
        return pd.Series(np.nan)
        
    # axis=1 averages across the rows (time intervals) for all turbines in the list
    return pd.concat(ws_data_points, axis=1).mean(axis=1)
def _get_theoretical_power(target_df, pc_df):
    """Calculates kW from local wind speed using the provided Power Curve."""
    temp = target_df.copy()
    # Replace 0 wind with NaN so it can trigger a fallback
    local_ws = temp.iloc[:, 1].replace(0, np.nan)
    temp['WS_R'] = local_ws.round(1)
    merged = pd.merge(temp, pc_df, left_on='WS_R', right_on='WS_Ref', how='left')
    return merged['Power_Ref'] # Returns NaN if local WS is missing

def _get_pwr_tiers(all_data, neighbors):
    """Gathers Power (kW) from ON-turbines only for Primary/Secondary tiers."""
    # Primary (Neighbors)
    if neighbors:
        p_pwr = pd.concat([_get_active_only_values(all_data[n], 2) for n in neighbors if n in all_data], axis=1).mean(axis=1)
    else:
        p_pwr = pd.Series(np.nan, index=next(iter(all_data.values())).index if all_data else [])

    # Secondary (Farm)
    if all_data:
        s_pwr = pd.concat([_get_active_only_values(df, 2) for df in all_data.values()], axis=1).mean(axis=1)
    else:
        s_pwr = pd.Series(np.nan, index=p_pwr.index)
        
    return p_pwr, s_pwr

def _finalize_results(target_df, ref_pwr_stream):
    """Produces the final results without filling NaNs (allowing data_iob to drop them)."""
    analysis_df = target_df.copy()
    ts_col = target_df.columns[0]
    actual_pwr_col = target_df.columns[2]
    
    # We keep NaNs here so they can be identified as "No Data" during export
    analysis_df['Power_Ref'] = ref_pwr_stream
    
    is_on = analysis_df[actual_pwr_col] > 0
    is_stop = (~is_on).fillna(True)
    
    return analysis_df, ts_col, is_on, is_stop

# --- THE 6 HIERARCHIES ---

def method_1(df_t, df_pc, all_d, n): 
    # Rule: Only remove if (No Local WS) AND (No active neighbors) AND (No active farm)
    theoretical = _get_theoretical_power(df_t, df_pc)
    p_pwr, s_pwr = _get_pwr_tiers(all_d, n)
    
    # Fallback order: Local PC -> Neighbor Power -> Farm Power
    ref = theoretical.combine_first(p_pwr).combine_first(s_pwr)
    return _finalize_results(df_t, ref)

def method_2(df_t, df_pc, all_d, n): 
    # Learned PC version of Method 1
    return method_1(df_t, df_pc, all_d, n)

def method_3(df_t, df_pc, all_d, n): 
    # Neighbor WS (Raw) -> Farm WS (Raw) -> Local WS -> Learned PC
    p_ws = _get_raw_ws_averages(all_d, n)
    s_ws = _get_raw_ws_averages(all_d, list(all_d.keys()))
    local_ws = df_t.iloc[:, 1].replace(0, np.nan)
    ws_final = p_ws.combine_first(s_ws).combine_first(local_ws).round(1)
    
    ws_df = pd.DataFrame({'WS_R': ws_final})
    merged = pd.merge(ws_df, df_pc, left_on='WS_R', right_on='WS_Ref', how='left')
    return _finalize_results(df_t, merged['Power_Ref'])

def method_4(df_t, df_pc, all_d, n): 
    # Farm WS (Raw) -> Local WS -> Learned PC
    s_ws = _get_raw_ws_averages(all_d, list(all_d.keys()))
    local_ws = df_t.iloc[:, 1].replace(0, np.nan)
    ws_final = s_ws.combine_first(local_ws).round(1)
    
    ws_df = pd.DataFrame({'WS_R': ws_final})
    merged = pd.merge(ws_df, df_pc, left_on='WS_R', right_on='WS_Ref', how='left')
    return _finalize_results(df_t, merged['Power_Ref'])

def method_5(df_t, all_d, n, df_pc): 
    # Primary PWR (Active) -> Secondary PWR (Active) -> Local WS PC
    p_pwr, s_pwr = _get_pwr_tiers(all_d, n)
    theoretical = _get_theoretical_power(df_t, df_pc)
    ref = p_pwr.combine_first(s_pwr).combine_first(theoretical)
    return _finalize_results(df_t, ref)

def method_6(df_t, all_d, df_pc): 
    # Secondary PWR (Active Farm) -> Local WS PC
    _, s_pwr = _get_pwr_tiers(all_d, [])
    theoretical = _get_theoretical_power(df_t, df_pc)
    ref = s_pwr.combine_first(theoretical)
    return _finalize_results(df_t, ref)

