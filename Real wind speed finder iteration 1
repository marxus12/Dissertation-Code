"""processing.py"""

import pandas as pd
import numpy as np

def load_data(turbine_path, power_curve_path, met_mast_path, curve_sheet):
    """
    Opens files and filters out rows with NaN or Power <= 0 in Column E.
    """
    # 1. Load the raw turbine data
    t1_data = pd.read_excel(turbine_path, engine='openpyxl')
    
    # 2. Filter: Column E (index 4) must be positive and not a number (NaN)
    power_kw_col = t1_data.columns[4]
    t1_data = t1_data.dropna(subset=[power_kw_col])
    t1_data = t1_data[t1_data[power_kw_col] > 0].copy()
    
    # 3. Load Power Curve (specific sheet) and Met Mast
    power_curve = pd.read_excel(power_curve_path, sheet_name=curve_sheet, engine='openpyxl')
    met_mast = pd.read_excel(met_mast_path, engine='openpyxl')
    
    return t1_data, power_curve, met_mast

def convert_energy_to_power(df):
    """
    Converts 'Energy Export (kWh)' in Column D (Index 3) to Power.
    Formula: Power = Energy / (1/6)
    """
    energy_col = df.columns[3]
    # Energy divided by 1/6 is the same as multiplying by 6
    df['calculated_power'] = df[energy_col] * 6 
    return df

def find_closest_wind_speed(target_power, power_curve):
    """
    Lookup: Finds the wind speed in the learned curve closest to the calculated power.
    Assumes Power Curve: Col A = Wind Speed, Col B = Power.
    """
    speed_col = power_curve.columns[0]
    power_col = power_curve.columns[1]
    
    # Find the index of the closest power match using absolute difference
    idx = (power_curve[power_col] - target_power).abs().idxmin()
    return power_curve.loc[idx, speed_col]

def process_turbine_analysis(turbine_file, curve_file, met_file, curve_sheet):
    # Load and Clean
    t1_data, power_curve, met_mast = load_data(turbine_file, curve_file, met_file, curve_sheet)
    
    # Transform Energy (Col D)
    t1_data = convert_energy_to_power(t1_data)
    
    # Map to Wind Speed
    t1_data['derived_wind_speed'] = t1_data['calculated_power'].apply(
        lambda x: find_closest_wind_speed(x, power_curve)
    )
    
    return t1_data, met_mast



