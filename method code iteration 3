import pandas as pd
import numpy as np
from configb import INTERVAL_HRS


def _get_active_only(dataframe, column_index):
    
    actual_power_values = dataframe.iloc[:, 2] # Index 2 is the Power column
    target_data_values = dataframe.iloc[:, column_index] 
    
    # If Power <= 0, replace data with NaN (Not a Number) so it is ignored in averages
    return target_data_values.where(actual_power_values > 0, np.nan)

def _build_wind_speed_streams(target_turbine_df, all_turbines_dict, neighbor_list):
    timestamp_column = target_turbine_df.columns[0]
    alignment_df = target_turbine_df[[timestamp_column]].copy()
    
    # Tier 1: Target's own anemometer reading
    alignment_df['target'] = target_turbine_df.iloc[:, 1]
    
    # Tier 2: Primary Neighbors (Average of those that are ON)
    primary_active = pd.concat([_get_active_only(all_turbines_dict[n], 1) for n in neighbor_list], axis=1).mean(axis=1)
    primary_raw = pd.concat([all_turbines_dict[n].iloc[:, 1] for n in neighbor_list], axis=1).mean(axis=1)
    alignment_df['primary'] = primary_active.combine_first(primary_raw)
    
    # Tier 3: Secondary Farm (Average of all turbines that are ON)
    secondary_active = pd.concat([_get_active_only(df, 1) for df in all_turbines_dict.values()], axis=1).mean(axis=1)
    secondary_raw = pd.concat([df.iloc[:, 1] for df in all_turbines_dict.values()], axis=1).mean(axis=1)
    alignment_df['secondary'] = secondary_active.combine_first(secondary_raw)
    
    return alignment_df



def _run_standard_merge(target_turbine_df, power_curve_df, wind_speed_series):
    working_df = target_turbine_df.copy()
    timestamp_col = target_turbine_df.columns[0]
    actual_power_col = target_turbine_df.columns[2]
    
    # Round the input wind speed to match the 0.1 increments in the Power Curve table
    working_df['WS_Rounded'] = wind_speed_series.round(1)
    
    # Merge telemetry with the reference curve; results in NaNs where wind doesn't match a row
    merged_results = pd.merge(working_df, power_curve_df, left_on='WS_Rounded', right_on='WS_Ref', how='left')
    
    # Define Power ON & OFF states
    is_running = merged_results[actual_power_col] > 0
    # treat NaNs (data gaps) as Stopped (True) so we calculate lost production for them
    is_stopped = (~is_running).fillna(True)
    
    # Convert kW to kWh and sum. skipna=True ensures we calculate totals even if some rows are missing.
    metrics = {
        'produced': (merged_results.loc[is_running, 'Power_Ref'] * INTERVAL_HRS).sum(skipna=True),
        'lost': (merged_results.loc[is_stopped, 'Power_Ref'] * INTERVAL_HRS).sum(skipna=True),
        'consumed': (merged_results.loc[is_stopped, actual_power_col] * INTERVAL_HRS).sum(skipna=True),
        'run_time': is_running.sum() * INTERVAL_HRS,
        'stop_time': is_stopped.sum() * INTERVAL_HRS,
        'avail': (is_running.sum() / len(merged_results)) * 100 if len(merged_results) > 0 else 0
    }
    return merged_results, metrics, timestamp_col, is_running, is_stopped

def _calculate_direct_power_metrics(target_turbine_df, reference_power_series):
    results_df = target_turbine_df.copy()
    timestamp_col = target_turbine_df.columns[0]
    actual_power_col = target_turbine_df.columns[2]
    
    # No merge needed; we force the Reference Power to be the Neighbor Average
    results_df['Power_Ref'] = reference_power_series
    results_df['WS_Rounded'] = target_turbine_df.iloc[:, 1] 
    
    is_running = results_df[actual_power_col] > 0
    is_stopped = (~is_running).fillna(True)
               
    metrics = {
        'produced': (results_df.loc[is_running, 'Power_Ref'] * INTERVAL_HRS).sum(skipna=True),
        'lost': (results_df.loc[is_stopped, 'Power_Ref'] * INTERVAL_HRS).sum(skipna=True),
        'consumed': (results_df.loc[is_stopped, actual_power_col] * INTERVAL_HRS).sum(skipna=True),
        'run_time': is_running.sum() * INTERVAL_HRS,
        'stop_time': is_stopped.sum() * INTERVAL_HRS,
        'avail': (is_running.sum() / len(results_df)) * 100 if len(results_df) > 0 else 0
    }
    return results_df, metrics, timestamp_col, is_running, is_stopped

# Hierachy Methods 
    def method_default_curve(df_target, df_pc, all_data, neighbors):
    streams = _build_wind_speed_streams(df_target, all_data, neighbors)
    final_ws = streams['target'].combine_first(streams['primary']).combine_first(streams['secondary'])
    return _run_standard_merge(df_target, df_pc, final_ws)

def method_learned_curve(df_target, df_pc, all_data, neighbors):
    streams = _build_wind_speed_streams(df_target, all_data, neighbors)
    final_ws = streams['target'].combine_first(streams['primary']).combine_first(streams['secondary'])
    return _run_standard_merge(df_target, df_pc, final_ws)

def method_primary_reference_pc(df_target, df_pc, all_data, neighbors):
    streams = _build_wind_speed_streams(df_target, all_data, neighbors)
    final_ws = streams['primary'].combine_first(streams['secondary']).combine_first(streams['target'])
    return _run_standard_merge(df_target, df_pc, final_ws)

def method_secondary_reference_pc(df_target, df_pc, all_data, neighbors):
    streams = _build_wind_speed_streams(df_target, all_data, neighbors)
    final_ws = streams['secondary'].combine_first(streams['target'])
    return _run_standard_merge(df_target, df_pc, final_ws)

def method_primary_reference_power(df_target, all_data, neighbors, df_pc):
    primary_power = pd.concat([_get_active_only(all_data[n], 2) for n in neighbors], axis=1).mean(axis=1)
    secondary_power = pd.concat([_get_active_only(df, 2) for df in all_data.values()], axis=1).mean(axis=1)
    
    # Last resort fallback: Model output from the learned PC
    temp_df = df_target.copy()
    temp_df['WS_R'] = df_target.iloc[:, 1].round(1)
    pc_lookup = pd.merge(temp_df, df_pc, left_on='WS_R', right_on='WS_Ref', how='left')
    learned_power = pc_lookup['Power_Ref']
    
    final_power = primary_power.combine_first(secondary_power).combine_first(learned_power)
    return _calculate_direct_power_metrics(df_target, final_power)

def method_secondary_reference_power(df_target, all_data, df_pc):
    secondary_power = pd.concat([_get_active_only(df, 2) for df in all_data.values()], axis=1).mean(axis=1)
    
    temp_df = df_target.copy()
    temp_df['WS_R'] = df_target.iloc[:, 1].round(1)
    pc_lookup = pd.merge(temp_df, df_pc, left_on='WS_R', right_on='WS_Ref', how='left')
    learned_power = pc_lookup['Power_Ref']
    
    final_power = secondary_power.combine_first(learned_power)
    return _calculate_direct_power_metrics(df_target, final_power)


