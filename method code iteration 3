from configb import POWER_CURVE_FILE, TURBINE_FILES, NEIGHBOR_MAP
from turbine_analyticsb import uib, data_iob, processingb

def run_main_application():
    try:
        # 1. User Inputs
        selected_file = uib.select_turbine_dataset()
        method_choice = uib.select_analysis_method()
        
        # Determine the sheet name for the learned power curve based on filename
        turbine_number = selected_file.split(' ')[1].replace('T','').lstrip('0')
        learned_sheet_name = f"Deeping T{turbine_number}"

        # 2. Data Loading
        # Load all data into a dictionary for neighbor-to-neighbor comparisons
        all_turbine_data = {f: data_iob.load_turbine_data(f) for f in TURBINE_FILES}
        target_df = all_turbine_data[selected_file]
        neighbor_list = NEIGHBOR_MAP.get(selected_file)

        # 3. Method Routing
        if method_choice == 1:
            power_curve_df = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, "Default PC")
            results = processingb.method_default_curve(target_df, power_curve_df, all_turbine_data, neighbor_list)
            reference_label = "Default PC (Hierarchy)"
            
        elif method_choice == 2:
            power_curve_df = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, learned_sheet_name)
            results = processingb.method_learned_curve(target_df, power_curve_df, all_turbine_data, neighbor_list)
            reference_label = f"{learned_sheet_name} (Hierarchy)"
            
        elif method_choice == 3:
            power_curve_df = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, learned_sheet_name)
            results = processingb.method_primary_reference_pc(target_df, power_curve_df, all_turbine_data, neighbor_list)
            reference_label = "Primary Ref PC (Filtered)"
            
        elif method_choice == 4:
            power_curve_df = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, learned_sheet_name)
            results = processingb.method_secondary_reference_pc(target_df, power_curve_df, all_turbine_data, neighbor_list)
            reference_label = "Secondary Ref PC (Filtered)"
            
        elif method_choice == 5:
            power_curve_df = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, learned_sheet_name)
            results = processingb.method_primary_reference_power(target_df, all_turbine_data, neighbor_list, power_curve_df)
            reference_label = "Primary Pwr Avg (Filtered)"
            
        elif method_choice == 6:
            power_curve_df = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, learned_sheet_name)
            results = processingb.method_secondary_reference_power(target_df, all_turbine_data, power_curve_df)
            reference_label = "Secondary Pwr Avg (Filtered)"

        # 4. Unpacking Results
        results_df, performance_metrics, timestamp_col, is_running, is_stopped = results

        # 5. UI and File Output
        uib.display_results_summary(selected_file, reference_label, performance_metrics)
        export_path = data_iob.export_results_to_excel(results_df, selected_file, timestamp_col, is_running, is_stopped)
        print(f"File exported successfully to: {export_path}")

    except Exception as error:
        print(f"A critical error occurred: {error}")

if __name__ == "__main__":
    run_main_application()
