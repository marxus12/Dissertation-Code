import pandas as pd

def load_turbine_data(turbine_file_path):
    return pd.read_excel(turbine_file_path, usecols="A,B,D", header=0)

def load_power_curve_sheet(power_curve_file, sheet_name):
    
    excel_file = pd.ExcelFile(power_curve_file)
    
    #error Check 
    if sheet_name not in excel_file.sheet_names:
        raise ValueError(f"Sheet '{sheet_name}' not found. Available: {excel_file.sheet_names}")
    
    power_curve_df = pd.read_excel(excel_file, sheet_name=sheet_name, header=0)
    
    #Rename columns to standardised names for the merge logic later
    power_curve_df.columns = ['WS_Ref', 'Power_Ref']
    return power_curve_df

def export_results_to_excel(analyzed_df, original_filename, timestamp_col, is_running_mask, is_stopped_mask):
    """Exports the processed results into an Excel file with separate ON/OFF sheets."""
    export_columns = [timestamp_col, 'WS_Rounded', 'Power_Ref']
    
    #Create copies of data filtered by turbine state
    running_data = analyzed_df.loc[is_running_mask, export_columns].copy()
    stopped_data = analyzed_df.loc[is_stopped_mask, export_columns].copy()
    
    #Format the timestamp strings for standard Excel readability
    for dataframe in [running_data, stopped_data]:
        dataframe[timestamp_col] = pd.to_datetime(dataframe[timestamp_col]).dt.strftime('%d-%m-%Y %H:%M')
    
    output_filename = f"Analysis_{original_filename}"
    
    # Save both dataframes into one file using multiple sheets
    with pd.ExcelWriter(output_filename) as excel_writer:
        running_data.to_excel(excel_writer, sheet_name='Turbine_ON', index=False)
        stopped_data.to_excel(excel_writer, sheet_name='Turbine_OFF', index=False)
        
    return output_filename


