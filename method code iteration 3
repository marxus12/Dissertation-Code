from configb import TURBINE_FILES

def select_turbine_dataset():
    print("\n--- Turbine Selection ---")
    for index, filename in enumerate(TURBINE_FILES, 1):
        print(f"[{index}] {filename}")
    
    choice_index = int(input("Selection (1-8): ")) - 1
    return TURBINE_FILES[choice_index]

def select_analysis_method():
    print("\n--- Calculation Method (with Fallback Hierarchies) ---")
    print("[1] Default PC (Own -> Primary -> Secondary)")
    print("[2] Learned PC (Own -> Primary -> Secondary)")
    print("[3] Primary Ref PC (Primary -> Secondary -> Own)")
    print("[4] Secondary Ref PC (Secondary -> Own)")
    print("[5] Primary Ref Pwr (Primary -> Secondary -> Learned PC)")
    print("[6] Secondary Ref Pwr (Secondary -> Learned PC)")
    return int(input("Choice (1-6): "))

def display_results_summary(turbine_name, reference_info, performance_metrics):
    print("\n" + "="*55)
    print(f"PERFORMANCE SUMMARY: {turbine_name}")
    print(f"Ref Source: {reference_info}")
    print("="*55)
    
    print(f"{'Actual Energy Produced':<35} : {performance_metrics['produced']:,.2f} kWh")
    print(f"{'Lost Production (Potential)':<35} : {performance_metrics['lost']:,.2f} kWh")
    print(f"{'Parasitic/Consumed Energy':<35} : {performance_metrics['consumed']:,.2f} kWh")
    print("-" * 55)
    
    print(f"{'Total Running Time':<35} : {performance_metrics['run_time']:.1f} hrs")
    print(f"{'Total Stopped Time':<35} : {performance_metrics['stop_time']:.1f} hrs")
    print(f"{'Availability (Time)':<35} : {performance_metrics['avail']:.2f}%")
    print("="*55)

