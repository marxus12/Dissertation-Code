# Mainb.py
from configb import POWER_CURVE_FILE, TURBINE_FILES, NEIGHBOR_MAP
from turbine_analyticsb import uib, data_iob, processingb

def run_application():
    try:
        target_file = uib.select_turbine_dataset()
        
        # Metadata for Power Curve Sheet
        t_id = target_file.split(' ')[1].replace('T','').lstrip('0')
        learned_sheet = f"Deeping T{t_id}"
        
        # Load Data
        all_data = {f: data_iob.load_turbine_data(f) for f in TURBINE_FILES}
        target_df = all_data[target_file]
        neighbors = NEIGHBOR_MAP.get(target_file)
        
        # EXCLUDE SELF: Create a list of farm turbines that are NOT the target
        other_turbines = [f for f in TURBINE_FILES if f != target_file]

        pc_def = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, "Default PC")
        pc_lrn = data_iob.load_power_curve_sheet(POWER_CURVE_FILE, learned_sheet)

        print(f"\nProcessing {target_file} (Strict Peer-Only Logic)...")
        results = {}
        
        results["1_Local_Default_PC"] = processingb.method_1(target_df, pc_def)
        results["2_Local_Learned_PC"] = processingb.method_2(target_df, pc_lrn)
        results["3_Neighbor_WS"]     = processingb.method_3(target_df, pc_lrn, all_data, neighbors)
        results["4_Farm_WS_Peer"]    = processingb.method_4(target_df, pc_lrn, all_data, other_turbines)
        results["5_Neighbor_kW"]     = processingb.method_5(target_df, all_data, neighbors)
        results["6_Farm_kW_Peer"]    = processingb.method_6(target_df, all_data, other_turbines)

        # Export
        final_path = data_iob.export_all_methods(results, target_file)
        uib.display_final_status(final_path)

    except Exception as e:
        print(f"\nCRITICAL ERROR: {e}")

if __name__ == "__main__":
    run_application()
