from configb import TURBINE_FILES

def select_turbine_dataset():
    print("\n--- Step 1: Select Turbine for Strict Analysis ---")
    for idx, f in enumerate(TURBINE_FILES, 1):
        print(f"[{idx}] {f}")
    choice = int(input("Selection (1-8): ")) - 1
    return TURBINE_FILES[choice]

def display_final_status(file_path):
    print("\n" + "="*50)
    print(f"STRICT ANALYSIS COMPLETE")
    print(f"Results exported to: {file_path}")
    print("="*50 + "\n")

