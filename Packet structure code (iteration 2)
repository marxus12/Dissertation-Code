import pandas as pd
from config import INTERVAL_HRS

def perform_turbine_analysis(turbine_dataframe, power_curve_dataframe):
    #Naming colunms from excel
    timestamp_column = turbine_dataframe.columns[0]
    wind_speed_column = turbine_dataframe.columns[1]
    actual_power_column = turbine_dataframe.columns[2]
    
    # Round wind speed to 1 dp
    turbine_dataframe['WS_Rounded'] = turbine_dataframe[wind_speed_column].round(1)
    
    # Merging data with the reference curve
    merged_data = pd.merge(
        turbine_dataframe, 
        power_curve_dataframe, 
        left_on='WS_Rounded', 
        right_on='WS_Ref', 
        how='left'
    )
    
    #cleaning the data by removing NaN values
    merged_data['Power_Ref'] = merged_data['Power_Ref'].fillna(0)
    
    #Defining Turbine ON & OFF
    is_running = merged_data[actual_power_column] > 0
    is_stopped = ~is_running
    
    # Energy and time metrics calculation
    performance_metrics = {
        'produced': (merged_data.loc[is_running, 'Power_Ref'] * INTERVAL_HRS).sum(),
        'lost': (merged_data.loc[is_stopped, 'Power_Ref'] * INTERVAL_HRS).sum(),
        'consumed': (merged_data.loc[is_stopped, actual_power_column] * INTERVAL_HRS).sum(),
        'run_time': is_running.sum() * INTERVAL_HRS,
        'stop_time': is_stopped.sum() * INTERVAL_HRS,
        'avail': (is_running.sum() / len(merged_data)) * 100
    }
    
    return merged_data, performance_metrics, timestamp_column, is_running, is_stopped


###dataio.py###

import pandas as pd

def load_turbine_and_curve_data(turbine_file, power_curve_file, power_curve_sheet):

    turbine_dataframe = pd.read_excel(turbine_file, usecols="A,B,D", header=0)
    power_curve_dataframe = pd.read_excel(power_curve_file, sheet_name=power_curve_sheet, header=0)
    
    power_curve_dataframe.columns = ['WS_Ref', 'Power_Ref']
    
    return turbine_dataframe, power_curve_dataframe

def export_results_to_excel(merged_dataframe, filename, timestamp_column, is_running, is_stopped):

    export_columns = [timestamp_column, 'WS_Rounded', 'Power_Ref']
    
    running_data = merged_dataframe.loc[is_running, export_columns].copy()
    stopped_data = merged_dataframe.loc[is_stopped, export_columns].copy()
    
    #Format timestamps for readability
    for dataframe in [running_data, stopped_data]:
        dataframe[timestamp_column] = pd.to_datetime(dataframe[timestamp_column]).dt.strftime('%d-%m-%Y %H:%M')
    #outputing file with sheet for tubrine ON & OFF table   
    output_filename = f"Analysis_{filename}"
    with pd.ExcelWriter(output_filename) as writer:
        running_data.to_excel(writer, sheet_name='Turbine_ON', index=False)
        stopped_data.to_excel(writer, sheet_name='Turbine_OFF', index=False)
        
    return output_filename

###Main.py###

from config import POWER_CURVE_FILE
from turbine_analytics import ui, data_io, processing

def main():
    try:
        #User Selection 
        selected_turbine_file, selected_power_curve_sheet = ui.select_input_files()
        
        #Loading Data
        turbine_df, power_curve_df = data_io.load_turbine_and_curve_data(
            selected_turbine_file, 
            POWER_CURVE_FILE, 
            selected_power_curve_sheet
        )
        
        #Processing Data
        merged_df, metrics, timestamp_col, is_run, is_stop = processing.perform_turbine_analysis(
            turbine_df, 
            power_curve_df
        )
        
        #Exporting Results
        output_file_path = data_io.export_results_to_excel(
            merged_df, 
            selected_turbine_file, 
            timestamp_col, 
            is_run, 
            is_stop
        )
        
        #UI Output
        ui.display_performance_summary(selected_turbine_file, selected_power_curve_sheet, metrics)
        print(f"Data successfully exported to: {output_file_path}\n")
        
    except Exception as error:
        print(f"An error occurred during execution: {error}")

if __name__ == "__main__":
    main()
